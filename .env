# ---------------------------------------------------------
# Copy this file to .env for local development.
# On Render / Heroku, set these as dashboard Environment Variables
# instead of uploading a .env file.
# ---------------------------------------------------------

# App
NODE_ENV=production
PORT=3000
# Full public URL of the deployed app, no trailing slash
# e.g. https://your-app.onrender.com or https://your-app.herokuapp.com
APP_URL=http://localhost:3000
APP_NAME=VaultGate

# Session / token signing secret - set this to a long random string
JWT_SECRET=change_this_to_a_long_random_string

# ---------------------------------------------------------
# Database - FreeSQLDatabase.com (MySQL) connection details
# Found on your FreeSQLDatabase.com control panel
# ---------------------------------------------------------
DB_HOST=sql.freesqldatabase.com
DB_PORT=3306
DB_USER=your_db_username
DB_PASSWORD=your_db_password
DB_NAME=your_db_name

# ---------------------------------------------------------
# SMTP - used to send verification & password reset emails
# Any SMTP provider works: Gmail (App Password), Outlook,
# SendGrid, Mailgun, Brevo, Zoho, etc.
# ---------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_smtp_app_password
SMTP_FROM_NAME=VaultGate
SMTP_FROM_EMAIL=your_email@gmail.com
