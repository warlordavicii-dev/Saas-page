<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <div class="app-shell">
    <%- include('partials/sidebar', { active: 'assistant' }) %>

    <main class="main-content">
    <div class="content-inner">

    <%- include('partials/flash') %>

    <div class="panel chat-panel">
      <h2>Assistant</h2>
      <p class="desc">Ask about deposits, withdrawals, the Community chat, or your account settings.</p>

      <div class="chat-messages" id="chat-messages">
        <div class="chat-msg chat-msg-bot">
          <div class="chat-msg-head"><span class="chat-msg-user">VaultGate Assistant</span></div>
          <div class="chat-msg-body"><%= welcomeMessage %></div>
        </div>
        <% history.forEach(function (m) { %>
          <div class="chat-msg <%= m.role === 'user' ? 'chat-msg-own' : 'chat-msg-bot' %>">
            <div class="chat-msg-head">
              <span class="chat-msg-user"><%= m.role === 'user' ? 'You' : 'VaultGate Assistant' %></span>
            </div>
            <div class="chat-msg-body"><%= m.content %></div>
          </div>
        <% }); %>
      </div>

      <form id="assistant-form" class="chat-form" autocomplete="off">
        <div class="chat-input-row">
          <textarea id="assistant-input" name="message" rows="1" maxlength="500" placeholder="Ask a question…" required></textarea>
          <button type="submit" class="btn btn-primary chat-send-btn" id="assistant-send-btn">Send</button>
        </div>
        <p class="hint" id="assistant-error" style="display:none;"></p>
      </form>
      <button type="button" id="assistant-reset-btn" class="chat-reply-btn" style="margin-top:6px;">Start a new conversation</button>
    </div>

    </div>
    </main>
  </div>

  <script>
    (function () {
      const messagesEl = document.getElementById('chat-messages');
      const form = document.getElementById('assistant-form');
      const input = document.getElementById('assistant-input');
      const sendBtn = document.getElementById('assistant-send-btn');
      const errorEl = document.getElementById('assistant-error');
      const resetBtn = document.getElementById('assistant-reset-btn');

      function escapeHtml(str) {
        const div = document.createElement('div');
        div.textContent = str == null ? '' : String(str);
        return div.innerHTML;
      }

      function addMessage(role, text) {
        const wrap = document.createElement('div');
        wrap.className = 'chat-msg ' + (role === 'user' ? 'chat-msg-own' : 'chat-msg-bot');
        wrap.innerHTML = `
          <div class="chat-msg-head"><span class="chat-msg-user">${role === 'user' ? 'You' : 'VaultGate Assistant'}</span></div>
          <div class="chat-msg-body">${escapeHtml(text)}</div>
        `;
        messagesEl.appendChild(wrap);
        messagesEl.scrollTop = messagesEl.scrollHeight;
        return wrap;
      }

      function addTypingIndicator() {
        const wrap = document.createElement('div');
        wrap.className = 'chat-msg chat-msg-bot';
        wrap.id = 'typing-indicator';
        wrap.innerHTML = `
          <div class="chat-msg-head"><span class="chat-msg-user">VaultGate Assistant</span></div>
          <div class="chat-msg-body">Thinking…</div>
        `;
        messagesEl.appendChild(wrap);
        messagesEl.scrollTop = messagesEl.scrollHeight;
        return wrap;
      }

      form.addEventListener('submit', function (e) {
        e.preventDefault();
        const message = input.value.trim();
        errorEl.style.display = 'none';
        if (!message) return;

        addMessage('user', message);
        input.value = '';
        input.style.height = 'auto';
        sendBtn.disabled = true;
        const typingEl = addTypingIndicator();

        fetch('/assistant/message', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ message })
        })
          .then((res) => res.json().then((data) => ({ ok: res.ok, data })))
          .then(({ ok, data }) => {
            typingEl.remove();
            if (!ok) {
              errorEl.textContent = data.error || 'Something went wrong.';
              errorEl.style.display = 'block';
              return;
            }
            addMessage('assistant', data.reply);
          })
          .catch(() => {
            typingEl.remove();
            errorEl.textContent = 'Network error — please try again.';
            errorEl.style.display = 'block';
          })
          .finally(() => {
            sendBtn.disabled = false;
          });
      });

      input.addEventListener('input', function () {
        input.style.height = 'auto';
        input.style.height = Math.min(input.scrollHeight, 120) + 'px';
      });

      input.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' && !e.shiftKey) {
          e.preventDefault();
          form.requestSubmit();
        }
      });

      resetBtn.addEventListener('click', function () {
        fetch('/assistant/reset', { method: 'POST' }).then(function () {
          window.location.reload();
        });
      });

      messagesEl.scrollTop = messagesEl.scrollHeight;
    })();
  </script>
</body>
</html>
