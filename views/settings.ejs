<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <div class="hacklink-bg" id="hacklink-bg"></div>
  <div class="hacklink-pulse" id="hacklink-pulse"></div>

  <div class="settings-wrap">
    <div class="settings-header">
      <%- include('partials/brand') %>
      <div class="header-actions">
        <a href="/community" class="btn btn-secondary" style="width:auto;padding:9px 16px;">Community</a>
        <a href="/assistant" class="btn btn-secondary" style="width:auto;padding:9px 16px;">Assistant</a>
        <a href="/funds" class="btn btn-secondary" style="width:auto;padding:9px 16px;">Funds</a>
        <form class="logout-form" method="POST" action="/logout">
          <button class="btn btn-secondary" type="submit" style="width:auto;padding:9px 16px;">Log out</button>
        </form>
        <div class="menu-wrap">
          <button class="menu-btn" id="menu-btn" aria-label="Open menu" aria-haspopup="true" aria-expanded="false">&#8942;</button>
          <div class="dropdown" id="dropdown">
            <button id="open-about" type="button">About</button>
            <button id="open-settings" type="button">Settings</button>
          </div>
        </div>
      </div>
    </div>

    <%- include('partials/flash') %>

    <div class="panel" id="appearance-panel">
      <h2>Appearance</h2>
      <p class="desc">Choose how your dashboard background looks.</p>
      <div class="theme-toggle">
        <button type="button" class="theme-option" data-theme="hacklink" id="theme-hacklink-btn">
          <span class="theme-swatch swatch-hacklink"></span>
          HackLink
        </button>
        <button type="button" class="theme-option" data-theme="classic" id="theme-classic-btn">
          <span class="theme-swatch swatch-classic"></span>
          Classic
        </button>
      </div>
    </div>

    <div class="panel" id="profile-panel">
      <h2>Profile</h2>
      <p class="desc">
        Update your name and email.
        <span class="badge <%= user.is_verified ? 'verified' : 'unverified' %>">
          <%= user.is_verified ? '✓ verified' : '! unverified' %>
        </span>
      </p>
      <form method="POST" action="/settings/profile">
        <div class="field">
          <label for="name">Full name</label>
          <input type="text" id="name" name="name" value="<%= user.name %>" required>
        </div>
        <div class="field">
          <label for="username">Username</label>
          <input type="text" id="username" name="username" value="<%= user.username %>" minlength="3" maxlength="32" pattern="[a-zA-Z0-9_]+" required autocomplete="off">
          <p class="hint" id="username-status"></p>
        </div>
        <div class="field">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" value="<%= user.email %>" required>
          <p class="hint">Changing your email will require re-verifying it, and you'll be logged out.</p>
        </div>
        <button class="btn btn-primary" type="submit">Save profile</button>
      </form>
    </div>

    <script>
      (function () {
        const input = document.getElementById('username');
        const status = document.getElementById('username-status');
        const originalUsername = input.value.trim().toLowerCase();
        let debounceTimer = null;

        function setStatus(text, className) {
          status.textContent = text;
          status.className = 'hint ' + (className || '');
        }

        input.addEventListener('input', function () {
          const value = input.value.trim();

          if (!value || value.toLowerCase() === originalUsername) {
            setStatus('', '');
            return;
          }
          if (!/^[a-zA-Z0-9_]{3,32}$/.test(value)) {
            setStatus('3-32 characters: letters, numbers, or underscores.', 'status-error');
            return;
          }

          setStatus('Checking availability…', 'status-checking');
          clearTimeout(debounceTimer);
          debounceTimer = setTimeout(function () {
            fetch('/check-username?username=' + encodeURIComponent(value))
              .then(function (res) { return res.json(); })
              .then(function (data) {
                if (input.value.trim() !== value) return;
                if (data.available) {
                  setStatus('✓ Username is available', 'status-success');
                } else {
                  setStatus(data.reason || 'That username is taken.', 'status-error');
                }
              })
              .catch(function () {
                setStatus('Could not check right now.', 'status-error');
              });
          }, 400);
        });
      })();
    </script>

    <div class="panel">
      <h2>Change password</h2>
      <p class="desc">Choose a strong password you're not using elsewhere.</p>
      <form method="POST" action="/settings/password">
        <div class="field">
          <label for="currentPassword">Current password</label>
          <input type="password" id="currentPassword" name="currentPassword" required>
        </div>
        <div class="field">
          <label for="newPassword">New password</label>
          <input type="password" id="newPassword" name="newPassword" minlength="8" required>
        </div>
        <div class="field">
          <label for="confirmPassword">Confirm new password</label>
          <input type="password" id="confirmPassword" name="confirmPassword" minlength="8" required>
        </div>
        <button class="btn btn-primary" type="submit">Update password</button>
      </form>
    </div>
    <div class="panel" id="links-panel">
      <h2>Community &amp; support</h2>
      <p class="desc">Reach the VaultGate team or join the community.</p>
      <nav class="links-grid" aria-label="Community and support links">
        <a class="link-btn" href="https://whatsapp.com/channel/0029Vb6jxRD7IUYbQfokIu2s" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp channel (opens in a new tab)">
          <i class="fab fa-whatsapp" aria-hidden="true"></i> WhatsApp channel
        </a>
        <a class="link-btn" href="https://whatsapp.com/channel/0029Vb62TDsAYlUBrGoU1y3S" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp backup channel (opens in a new tab)">
          <i class="fab fa-whatsapp" aria-hidden="true"></i> Backup channel
        </a>
        <a class="link-btn" href="https://chat.whatsapp.com/IWTPLw7WogG0sc5L4u2syz?mode=ac_t" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp group (opens in a new tab)">
          <i class="fab fa-whatsapp" aria-hidden="true"></i> WhatsApp group
        </a>
        <a class="link-btn" href="https://wa.me/254769677305" target="_blank" rel="noopener noreferrer" aria-label="Contact support on WhatsApp (opens in a new tab)">
          <i class="fas fa-headset" aria-hidden="true"></i> Contact support
        </a>
        <a class="link-btn" href="https://wa.me/254740368834" target="_blank" rel="noopener noreferrer" aria-label="Contact Artisan Due on WhatsApp (opens in a new tab)">
          <i class="fas fa-headset" aria-hidden="true"></i> Contact Artisan Due
        </a>
        <a class="link-btn" href="https://wa.me/254788409105" target="_blank" rel="noopener noreferrer" aria-label="Contact Nicky on WhatsApp (opens in a new tab)">
          <i class="fas fa-headset" aria-hidden="true"></i> Contact Nicky
        </a>
      </nav>
    </div>
  </div>

  <div class="modal-overlay" id="about-overlay">
    <div class="modal">
      <button class="modal-close" data-close type="button">&times;</button>
      <h3>About VaultGate</h3>
      <p>VaultGate is your account dashboard for managing your profile, username, email, and password in one secure place.</p>
    </div>
  </div>

  <script>
    (function () {
      const menuBtn = document.getElementById('menu-btn');
      const dropdown = document.getElementById('dropdown');
      const aboutOverlay = document.getElementById('about-overlay');
      const profilePanel = document.getElementById('profile-panel');

      function closeDropdown() {
        dropdown.classList.remove('open');
        menuBtn.setAttribute('aria-expanded', 'false');
      }

      menuBtn.addEventListener('click', function (e) {
        e.stopPropagation();
        const isOpen = dropdown.classList.toggle('open');
        menuBtn.setAttribute('aria-expanded', String(isOpen));
      });

      document.addEventListener('click', function (e) {
        if (!dropdown.contains(e.target) && e.target !== menuBtn) closeDropdown();
      });

      document.getElementById('open-about').addEventListener('click', function () {
        closeDropdown();
        aboutOverlay.classList.add('open');
      });

      document.getElementById('open-settings').addEventListener('click', function () {
        closeDropdown();
        profilePanel.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });

      document.querySelectorAll('[data-close]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          aboutOverlay.classList.remove('open');
        });
      });

      aboutOverlay.addEventListener('click', function (e) {
        if (e.target === aboutOverlay) aboutOverlay.classList.remove('open');
      });

      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') {
          aboutOverlay.classList.remove('open');
          closeDropdown();
        }
      });
    })();
  </script>
</body>
</html>
